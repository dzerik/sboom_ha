{
  "config": {
    "flow_title": "{name} ({host})",
    "step": {
      "user": {
        "title": "SberBoom — IP-адрес колонки",
        "description": "Введите локальный IP-адрес колонки SberBoom.",
        "data": {
          "host": "IP-адрес",
          "port": "Порт",
          "client_name": "Имя клиента (будет видно в личном кабинете Sber)"
        }
      },
      "discovery_confirm": {
        "title": "Найдена колонка {name}",
        "description": "В локальной сети обнаружена колонка SberBoom:\n- Имя: {name}\n- IP: {host}\n- Модель: {model}\n\nНажмите Submit для начала привязки.",
        "data": {
          "client_name": "Имя клиента (будет видно в личном кабинете Sber)"
        }
      },
      "pair": {
        "title": "Подтверждение привязки",
        "description": "Колонка {name} ({host}) ждёт подтверждения.\n\n**Нажмите кнопку \"+\" на корпусе колонки**, затем нажмите Submit.\n\n(Таймаут: {timeout} сек)"
      },
      "reconfigure": {
        "title": "Изменить адрес колонки {name}",
        "description": "Изменить IP/порт уже привязанной колонки. PIN-токен сохраняется.",
        "data": {
          "host": "IP-адрес",
          "port": "Порт"
        }
      },
      "reauth_confirm": {
        "title": "Повторное сопряжение {name}",
        "description": "Колонке {name} ({host}) требуется повторная авторизация (например, после сброса к заводским настройкам).\n\n**Нажмите кнопку «+» на колонке**, затем подтвердите.\n\n(Таймаут: {timeout} секунд)"
      }
    },
    "error": {
      "cannot_connect": "Не удалось подключиться. Проверьте IP/порт и доступность колонки в локальной сети.",
      "pair_timeout": "Кнопка \"+\" не была нажата вовремя. Попробуйте ещё раз."
    },
    "abort": {
      "already_configured": "Эта колонка уже добавлена.",
      "incomplete_discovery": "Обнаруженный сервис не содержит ID устройства.",
      "reauth_successful": "Повторная авторизация выполнена.",
      "reconfigure_successful": "Настройки обновлены."
    }
  },
  "issues": {
